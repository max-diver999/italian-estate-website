export const prerender = true;

const reportDate = '10 July 2026';
const reportVersion = 'v3.0';
const launchDate = 'May 2026';
const dataThrough = '7 July 2026';

const monthlyGsc = [
  {
    "month": "May 2026",
    "label": "May",
    "clicks": 0,
    "impressions": 0,
    "position": 0,
    "note": "Pre-crawl · sitemap submitted · indexing API live"
  },
  {
    "month": "Jun 2026",
    "label": "Jun",
    "clicks": 6,
    "impressions": 1514,
    "position": 18.4,
    "note": "First impressions 17 Jun · first clicks 26 Jun"
  },
  {
    "month": "Jul 2026",
    "label": "Jul",
    "clicks": 6,
    "impressions": 1747,
    "position": 6.1,
    "note": "Partial · 7 days · avg pos broke into top 10"
  }
];

const monthlyGa4 = [
  { "month": "Jun", "sessions": 61 },
  { "month": "Jul", "sessions": 49 }
];

const contentBreakdown = [
  { "type": "Guides", "count": 90, "words": 389137, "color": "#2d7a5e" },
  { "type": "Projects", "count": 65, "words": 146111, "color": "#4e9e7e" },
  { "type": "Areas", "count": 48, "words": 159855, "color": "#8b5cf6" },
  { "type": "Comparisons", "count": 30, "words": 106703, "color": "#d97706" },
  { "type": "Developers", "count": 15, "words": 35703, "color": "#4e9e7e" },
  { "type": "News", "count": 4, "words": 4739, "color": "#60a5fa" }
];

const totalClicks = monthlyGsc.reduce((s, m) => s + m.clicks, 0);
const totalImp = monthlyGsc.reduce((s, m) => s + m.impressions, 0);
const totalWords = contentBreakdown.reduce((s, c) => s + c.words, 0);
const totalFiles = contentBreakdown.reduce((s, c) => s + c.count, 0);
const ga4Sessions = monthlyGa4.reduce((s, m) => s + m.sessions, 0);
const gsc28d = { clicks: 12, impressions: 3261, ctr: 0.37, position: 11.8 };
const impMomPct = monthlyGsc[1]?.impressions
  ? Math.round(((monthlyGsc[2].impressions - monthlyGsc[1].impressions) / monthlyGsc[1].impressions) * 100)
  : 0;
const posImprove = monthlyGsc[1]?.position
  ? (monthlyGsc[1].position - monthlyGsc[2].position).toFixed(1)
  : '0';

const dailyRaw = [
  { d: '06-17', c: 0, i: 17 }, { d: '06-18', c: 0, i: 44 }, { d: '06-19', c: 0, i: 49 },
  { d: '06-20', c: 0, i: 88 }, { d: '06-21', c: 0, i: 89 }, { d: '06-22', c: 0, i: 77 },
  { d: '06-23', c: 0, i: 106 }, { d: '06-24', c: 0, i: 91 }, { d: '06-25', c: 0, i: 77 },
  { d: '06-26', c: 1, i: 104 }, { d: '06-27', c: 0, i: 177 }, { d: '06-28', c: 1, i: 223 },
  { d: '06-29', c: 3, i: 191 }, { d: '06-30', c: 1, i: 181 }, { d: '07-01', c: 0, i: 192 },
  { d: '07-02', c: 2, i: 234 }, { d: '07-03', c: 0, i: 192 }, { d: '07-04', c: 0, i: 316 },
  { d: '07-05', c: 2, i: 345 }, { d: '07-06', c: 2, i: 252 }, { d: '07-07', c: 0, i: 216 }
];

const chartPayload = JSON.stringify({
  monthlyGsc: monthlyGsc.map(m => ({ label: m.label, clicks: m.clicks, impressions: m.impressions })),
  monthlyGa4,
  contentBreakdown: contentBreakdown.map(c => ({ type: c.type, count: c.count, color: c.color })),
  dailyRaw
});
