        </tr>
        <tr>
          <td><strong>Developers</strong><br><span class="words">Developer / agency profiles</span></td>
          <td><span class="count">15</span></td>
          <td><span class="words">24,821</span></td>
          <td><span class="words">1,655</span></td>
          <td><span class="tag blue">1 200+</span></td>
          <td><span class="tag green">Live</span></td>
        </tr>
        <tr>
          <td><strong>Guides</strong><br><span class="words">Legal, tax, investment HUBs, buyer personas</span></td>
          <td><span class="count">70</span></td>
          <td><span class="words">219,380</span></td>
          <td><span class="words">3,134</span></td>
          <td><span class="tag blue">2 000+</span></td>
          <td><span class="tag green">Live</span></td>
        </tr>
        <tr>
          <td><strong>News</strong><br><span class="words">Market updates</span></td>
          <td><span class="count">4</span></td>
          <td><span class="words">2,722</span></td>
