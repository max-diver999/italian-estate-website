---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
import FaqBlock from '../../components/FaqBlock.astro';
import CommercialBudgetLadder from '../../components/CommercialBudgetLadder.astro';
import CommercialSharedSections from '../../components/CommercialSharedSections.astro';
import { STICKY_SHORTLIST } from '../../data/sticky-cta';

const faqItems = [
  {
    question: 'What do I receive after submitting the shortlist form?',
    answer: 'Within one business day you get 3–5 vetted options matched to your budget band and region, with price range, yield notes where relevant, and links to our due diligence guides. No developer pressure and no buyer-side commission from Italian Estate.',
  },
  {
    question: 'Which Italian regions can you shortlist?',
    answer: 'Tuscany, Puglia, Milan/Lombardy, Lake Como, Liguria, Sardinia, Sicily, and Rome/Lazio. Tell us your goal (yield, holiday home, off-plan, relocation) and we filter accordingly.',
  },
  {
    question: 'Do you sell property directly?',
    answer: 'No. Italian Estate publishes independent research. When you request a shortlist we may introduce a licensed Italian agency or developer partner after you opt in. Always verify cadastral records, IMU, and STR rules before any deposit.',
  },
  {
    question: 'How is this different from Idealista or Gate-away?',
    answer: 'Portals optimise for volume. We publish due diligence guides, project reviews, and area benchmarks, then match a small set of options to your budget rather than sending every listing in a province.',
  },
  {
    question: 'Can I request off-plan Milan or Puglia villa projects?',
    answer: 'Yes. Reference projects like Inspire UpTown Milan, Prandina Navigli, or Ostuni pool villas are on our site. We connect you to partners only after you review published risk notes and milestone structures.',
  },
];
---
<BaseLayout
  title="Italy Property Shortlist for Foreign Buyers"
  description="Free independent shortlist for Italy property buyers. Tuscany, Puglia, Milan, Lake Como — budget-matched options within one business day. Not a portal."
  stickyCta={STICKY_SHORTLIST}
>
  <section class="site-container py-12 md:py-16 max-w-3xl">
    <CommercialBudgetLadder />
    <header class="mb-8">
      <span class="badge-pill mb-4">Free · Independent</span>
      <h1 class="mb-3">Get your Italy property shortlist</h1>
      <p class="text-lg text-[var(--color-muted)]">
        Share budget, region, and goal. We match you with vetted resale, off-plan, and new-build options — no spam, no listing portal noise.
      </p>
    </header>

    <div class="prose mb-10 text-[var(--color-muted)]">
      <p><strong>Quick answer:</strong> Foreign buyers can own freehold residential property across Italy subject to reciprocity checks at the notary. Entry from roughly €150k in Puglia or Sicily countryside; Milan and Lake Como start higher. Budget 10–12% on top of price for taxes, notary, and registration on a second home.</p>

      <h2 class="text-xl text-[var(--color-ink)]">Regional commercial landings</h2>
      <ul>
        <li><a href="/invest-tuscany-property/">Invest Tuscany</a> — Chianti, Florence, Lucca</li>
        <li><a href="/invest-puglia-property/">Invest Puglia</a> — Ostuni, Valle d'Itria, Salento</li>
        <li><a href="/invest-milan-property/">Invest Milan</a> — off-plan and corporate rental</li>
        <li><a href="/invest-rome-property/">Invest Rome</a> — Jubilee 2026, centro storico, Prati</li>
        <li><a href="/invest-lake-como-property/">Invest Lake Como</a> — lakefront and hillside</li>
        <li><a href="/invest-sicily-property/">Invest Sicily</a> — Taormina, Syracuse, Palermo</li>
        <li><a href="/invest-sardinia-property/">Invest Sardinia</a> — Costa Smeralda and coast</li>
        <li><a href="/invest-liguria-property/">Invest Liguria</a> — Riviera vs Como value</li>
        <li><a href="/italy-property-consultation/">Cross-region consultation</a></li>
      </ul>

      <h2 class="text-xl text-[var(--color-ink)]">Budget tiers</h2>
      <p>
        Browse by ticket size: <a href="/tier-entry/">Under €200k</a> · <a href="/tier-mid/">€200k–€500k</a> · <a href="/tier-luxury/">Luxury €500k+</a>
      </p>

      <p>Research: <a href="/guides/buy-property-italy-foreigner/">Buy property in Italy as a foreigner</a> · <a href="/guides/cost-of-buying-property-italy/">Closing costs</a> · <a href="/guides/due-diligence-italy-property/">Due diligence</a> · <a href="/guides/best-regions-invest-italy-property-2026/">Best regions 2026</a></p>
    </div>

    <LeadForm
      title="Request your shortlist"
      subtitle="Tuscany · Puglia · Milan · Lake Como · Sicily"
      context="Get shortlist page"
    />

    <CommercialSharedSections />

    <FaqBlock items={faqItems} />

    <p class="text-xs text-[var(--color-muted)] mt-6">
      By submitting you agree to our <a href="/privacy-policy/">Privacy Policy</a>. Not financial, tax, or legal advice.
    </p>
  </section>
</BaseLayout>
