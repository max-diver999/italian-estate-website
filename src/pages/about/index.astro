---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';
import { STICKY_ABOUT } from '../../data/sticky-cta';
---
<BaseLayout
  title="About Italian Estate"
  description="Italian Estate is an independent editorial resource on Italy property investment — not a developer or listing portal."
  stickyCta={STICKY_ABOUT}
>
  <section class="site-container py-12 md:py-16 max-w-3xl">
    <h1 class="mb-6">About {SITE.name}</h1>
    <div class="prose">
      <p>
        {SITE.name} publishes research-first guides for foreign buyers evaluating Milan, Rome, Tuscany, Puglia, and the Italian lakes.
        We are <strong>not</strong> a developer, not a property portal, and not a substitute for licensed legal or tax advice.
      </p>
      <h2>What we do</h2>
      <ul>
        <li>Explain codice fiscale, IMU, cedolare secca, CIN/SCIA short-term rules, and cadastral due diligence in plain English</li>
        <li>Compare markets and product types (city vs coastal, off-plan vs resale, LTR vs holiday let)</li>
        <li>Connect serious enquiries to <strong>licensed Italian partners</strong> when you request a shortlist</li>
      </ul>
      <h2>What we don't do</h2>
      <ul>
        <li>Push specific developer inventory or take undisclosed referral fees without disclosure</li>
        <li>Guarantee yields, capital appreciation, or visa outcomes</li>
        <li>Provide personalised financial, legal, or tax advice</li>
      </ul>
      <p>
        Questions? Email <a href={`mailto:${SITE.email}`}>{SITE.email}</a> or read our
        <a href="/methodology/">methodology</a>.
      </p>
    </div>
  </section>
</BaseLayout>
